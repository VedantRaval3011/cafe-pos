; Copy this file to ".env" (do NOT commit .env to GitHub)
; XAMPP local example

; App URLs
APP_URL="http://localhost/coffee"
ADMIN_URL="http://localhost/coffee/admin-panel"

; Database
DB_HOST="localhost"
DB_USER="root"
DB_PASS=""
DB_NAME="ns_coffee"

; Razorpay (Test Mode)
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_key_secret"

; SMTP (optional for invoice emailing)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="your_email@gmail.com"
SMTP_PASSWORD="your_app_password"
SMTP_FROM_EMAIL="your_email@gmail.com"
SMTP_FROM_NAME="NS Coffee"

; Admin login (optional bootstrap)
ADMIN_LOGIN_NAME="Admin"
ADMIN_LOGIN_EMAIL="admin@admin.com"
ADMIN_LOGIN_PASSWORD="admin@admin"

